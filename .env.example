# Copy to .env and adjust for your setup.
# docker compose / docker compose -f docker-compose.offline.yml pick this up automatically.

# Public base URL (used to build tile server URLs injected into the frontend)
BASE_URL=http://localhost:8000

# Port the app (online) or proxy (offline) listens on
APP_PORT=8000

# Docker image tag to pull/push  (default: latest)
IMAGE_TAG=latest

# ── Tile mode ────────────────────────────────────────────────────────────────
# online  → tiles fetched on-demand from CDN, cached locally (docker-compose.yml)
# offline → tiles served from pre-downloaded local dirs or baked Docker images
#           (docker-compose.offline.yml / K8s)
# Set automatically by the compose files; override here only if needed.
# TILE_MODE=online
