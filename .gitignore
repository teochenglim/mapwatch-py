# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Downloaded assets — regenerated on startup or docker build
data/*
!data/.gitkeep
static/lib/

# Tile cache — downloaded by CI, not committed (gitkeep preserves the directory)
tilemap-server/tiles/*
!tilemap-server/tiles/.gitkeep
